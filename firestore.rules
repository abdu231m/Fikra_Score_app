rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isAdmin() {
      return true;
    }

    function isValidStudent(data) {
      return data.keys().hasAll(['name', 'points', 'qrCode']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.points is number &&
             data.qrCode is string && data.qrCode.size() > 0 && data.qrCode.size() <= 1000 &&
             (!data.keys().contains('gallery') || (data.gallery is list && data.gallery.size() <= 30));
    }

    function isValidHistory(data) {
      return data.keys().hasAll(['title', 'endedAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.endedAt is string;
    }

    function isValidResult(data) {
      return data.keys().hasAll(['name', 'points', 'rank']) &&
             data.name is string && data.points is number && data.rank is number;
    }

    // --- Rules ---

    match /admins/{adminId} {
      allow read, write: if false; 
    }

    match /students/{studentId} {
      allow read: if true;
      allow update: if (
        (incoming().gallery.size() >= (existing().gallery.size())) ||
        (existing().keys().contains('gallery') == false)
      ) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['avatarUrl', 'gallery', 'updatedAt'])
      );
      allow create, delete, update: if true;
    }

    match /history/{historyId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidHistory(incoming());
      allow delete: if isAdmin();

      match /results/{resultId} {
        allow read: if true;
        allow create, update: if isAdmin() && isValidResult(incoming());
        allow delete: if isAdmin();
      }
    }
  }
}
