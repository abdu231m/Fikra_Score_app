rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isAdmin() {
      return isSignedIn() && 
             request.auth.token.email_verified == true &&
             (exists(/databases/$(database)/documents/admins/$(request.auth.uid)) || 
              request.auth.token.email == '4l8s.dream@gmail.com');
    }

    function isValidStudent(data) {
      return data.keys().hasAll(['name', 'points', 'qrCode']) &&
             data.keys().size() >= 3 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.points is number && data.points >= 0 &&
             data.qrCode is string && data.qrCode.size() > 0 && data.qrCode.size() <= 500;
    }

    // --- Rules ---

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && 
                     request.auth.token.email == '4l8s.dream@gmail.com' && 
                     request.auth.uid == adminId;
    }

    match /students/{studentId} {
      allow read: if true;
      allow write: if true; // In a real production app, we would use Firebase Auth. 
                            // Using public access for this specific "symbolic login" request.
    }
  }
}
